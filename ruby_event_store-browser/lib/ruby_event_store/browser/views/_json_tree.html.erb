<div class="font-[monospace] whitespace-pre">{<ul class="list-none ml-[26px] pl-0"><% hash.sort_by { |key, _| key.to_s }.each do |key, value| %><li class="relative"><span class="font-bold"><%= key %></span>: <span class="<%= case value when String then "text-[green]" when Numeric then "text-[blue]" when true, false then "text-[firebrick]" when nil then "text-[gray]" else "text-gray-800" end %>"><%= safe_json(value) %></span>,</li><% end %></ul>}</div>
